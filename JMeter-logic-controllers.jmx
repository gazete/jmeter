        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="8. Once Only Controller" enabled="true"/>
        <hashTree>
          <kg.apc.jmeter.samplers.DummySampler guiclass="kg.apc.jmeter.samplers.DummySamplerGui" testclass="kg.apc.jmeter.samplers.DummySampler" testname="Dummy - Executed Once Only" enabled="true">
            <boolProp name="WAITING">true</boolProp>
